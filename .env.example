# Copy to .env and set values (do not commit .env).
# For local dev with SQLite you can leave these unset.

# DJANGO_SECRET_KEY=your-secret-key
# DJANGO_DEBUG=True
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (optional; if not set, SQLite is used)
# USE_POSTGRES=1
# DB_NAME=lostfound_pets
# DB_USER=postgres
# DB_PASSWORD=yourpassword
# DB_HOST=localhost
# DB_PORT=5432

# Google Maps (required for map picker and geocoding)
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key
